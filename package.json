{
  "name": "pcms-cli",
  "version": "1.0.0",
  "description": "Payload CMS CLI — Type-safe REST API client for Payload CMS",
  "type": "module",
  "bin": {
    "pcms": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "prepublishOnly": "pnpm check && pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "payload",
    "payloadcms",
    "cms",
    "cli",
    "headless-cms",
    "rest-api"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mirkobozzetto/pcms-cli"
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  }
}
